# ── 基础 ────────────────────────────────────────────────────────────────────
# 未配置时脚本不会直接报死：缺 API_KEY 会返回 RECOVERY[API_KEY_MISSING]，
# 引导用户去注册页（CLAWDOT_SETUP_URL）拿 key 后由 agent 写入本文件。
GATEWAY_URL=https://gateway.example.com
API_KEY=your-api-key

# ── 鉴权（三选一）─────────────────────────────────────────────────────────
# Personal 模式：单用户长期复用同一个 user_token
USER_TOKEN=your-user-token

# Agent 模式：多用户共用一个 agent，靠手机号动态 trustedBind 换 token
# 取消注释并填上 admin 密钥，调脚本时 `--phone <11 位手机号>` 即可
# ADMIN_SECRET=your-admin-secret

# 用户绑定模式：USER_TOKEN 和 ADMIN_SECRET 都不配即生效。
# 业务调用会返回 RECOVERY[USER_NOT_BOUND_NEEDS_SMS]，由用户选择
# 短信验证码（默认，request_code → verify_code）或
# H5 链接授权（request_code --auth-type h5 → verify_code --auth-type h5 --request-id）。

# ── 可选 ────────────────────────────────────────────────────────────────────
# API_KEY 缺失时引导用户注册/登录的页面地址（默认 ClawDot developer 登录页）
# CLAWDOT_SETUP_URL=https://clawdot.hicaspian.com/developer/login

# 跨进程共享 trustedBind 出来的 user_token（agent 模式高频调用建议开）
# REDIS_URL=redis://127.0.0.1:6379/0

# Personal 模式冷启动用的兜底坐标（账号还没有任何 saved 地址时）；agent 模式忽略
DEFAULT_LAT=31.2304
DEFAULT_LNG=121.4737
